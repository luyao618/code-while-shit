# cws configuration — copy to .env and fill in.
# These env vars OVERRIDE the global config at ~/.config/cws/config.toml
# Do NOT commit this file.
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Optional: override agent (codex | claude-code | opencode)
# Also settable via: cws config set agent.default codex
# CWS_AGENT=claude-code

# Optional: comma-separated open_ids allowlist
# FEISHU_ALLOWED_USERS=

# Optional: override runtime dir (default: ~/.local/share/cws/runtime/<workspace_hash>/)
# CWS_RUNTIME_DIR=
